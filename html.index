<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Harry Chouhan — Video Editor</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#080808;--bg2:#0f0f0f;--accent:#ff3c1f;--accent2:#ff6b00;--white:#f5f5f0;--gray:#888880;--border:rgba(255,255,255,0.07)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--white);font-family:'DM Sans',sans-serif;overflow-x:hidden}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:22px 60px;background:rgba(8,8,8,0.97);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:3px;color:var(--white);text-decoration:none}
.nav-logo span{color:var(--accent)}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{font-size:12px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--gray);text-decoration:none;transition:color .3s}
.nav-links a:hover{color:var(--white)}
.nav-hire{background:var(--accent);color:var(--white)!important;padding:10px 22px;border-radius:2px;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none;transition:background .3s}
.nav-hire:hover{background:var(--accent2)!important}
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:130px 60px 80px;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 70% 50%,rgba(255,60,31,.07),transparent 70%),radial-gradient(ellipse 40% 60% at 20% 80%,rgba(255,107,0,.04),transparent 60%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);background-size:80px 80px}
.hero-left{position:relative;z-index:2}
.hero-tag{display:inline-flex;align-items:center;gap:8px;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);font-weight:500;margin-bottom:24px;opacity:0;animation:fadeUp .8s .2s forwards}
.hero-tag::before{content:'';width:24px;height:1px;background:var(--accent)}
.hero-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(68px,9vw,125px);line-height:.9;letter-spacing:2px;color:var(--white);opacity:0;animation:fadeUp .8s .4s forwards}
.hero-name .acc{color:transparent;-webkit-text-stroke:1px var(--accent)}
.hero-desc{font-size:15px;line-height:1.75;color:var(--gray);max-width:420px;margin:28px 0 44px;font-weight:300;opacity:0;animation:fadeUp .8s .6s forwards}
.hero-desc strong{color:var(--white);font-weight:500}
.hero-btns{display:flex;gap:16px;align-items:center;flex-wrap:wrap;opacity:0;animation:fadeUp .8s .8s forwards}
.btn-red{background:var(--accent);color:var(--white);padding:14px 30px;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all .3s;display:inline-flex;align-items:center;gap:8px}
.btn-red:hover{background:var(--accent2);transform:translateY(-2px)}
.btn-ghost{color:var(--white);font-family:'Syne',sans-serif;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;text-decoration:none;display:inline-flex;align-items:center;gap:8px;border-bottom:1px solid rgba(255,255,255,.25);padding-bottom:3px;transition:all .3s}
.btn-ghost:hover{color:var(--accent);border-color:var(--accent)}
.hero-right{position:relative;z-index:2;display:flex;justify-content:flex-end;opacity:0;animation:fadeIn 1s .5s forwards}
.photo-wrap{position:relative;width:400px;height:500px}
.photo-wrap::before{content:'';position:absolute;inset:-2px;background:linear-gradient(135deg,var(--accent),transparent 50%,var(--accent2));border-radius:4px;z-index:-1;opacity:.5}
.hero-photo{width:100%;height:100%;object-fit:cover;border-radius:3px;filter:grayscale(15%) contrast(1.05)}
.badge1{position:absolute;top:28px;left:-28px;background:var(--bg2);border:1px solid var(--border);border-radius:3px;padding:12px 16px;font-family:'Syne',sans-serif}
.badge1-num{font-size:26px;font-weight:800;color:var(--accent);line-height:1}
.badge1-txt{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--gray);margin-top:2px}
.badge2{position:absolute;bottom:36px;left:-36px;background:var(--accent);border-radius:3px;padding:10px 14px;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:1px;color:var(--white);text-transform:uppercase}
.marquee-wrap{overflow:hidden;border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:16px 0;background:var(--bg2)}
.marquee-track{display:flex;gap:50px;animation:marquee 25s linear infinite;white-space:nowrap;width:max-content}
.m-item{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:4px;color:var(--gray);flex-shrink:0}
.m-item span{color:var(--accent);margin:0 16px}
.stats-bar{padding:30px 60px;display:grid;grid-template-columns:repeat(4,1fr);background:var(--bg2);border-bottom:1px solid var(--border)}
.stat-item{text-align:center;border-right:1px solid var(--border);padding:0 16px}
.stat-item:last-child{border-right:none}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:44px;color:var(--white);line-height:1}
.stat-num span{color:var(--accent)}
.stat-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gray);margin-top:4px}
section{padding:90px 60px}
.sec-tag{display:inline-flex;align-items:center;gap:10px;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);font-weight:500;margin-bottom:14px}
.sec-tag::before{content:'';width:20px;height:1px;background:var(--accent)}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(44px,5.5vw,76px);line-height:.95;color:var(--white);margin-bottom:54px}
.sec-title .ol{color:transparent;-webkit-text-stroke:1px rgba(255,255,255,.18)}
.skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.sk-card{background:var(--bg2);padding:36px 32px;border:1px solid var(--border);transition:all .4s;position:relative;overflow:hidden}
.sk-card::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:2px;background:linear-gradient(to right,var(--accent),var(--accent2));transform:scaleX(0);transform-origin:left;transition:transform .4s}
.sk-card:hover::after{transform:scaleX(1)}
.sk-card:hover{transform:translateY(-4px);background:#121212}
.sk-num{font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;color:var(--accent);margin-bottom:14px}
.sk-name{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--white);margin-bottom:10px;line-height:1.2}
.sk-desc{font-size:13px;line-height:1.6;color:var(--gray);font-weight:300}
.sk-icon{font-size:28px;margin-bottom:18px;display:block}
.tools-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:36px}
.tool{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border:1px solid var(--border);border-radius:2px;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--white);background:var(--bg2);transition:all .3s}
.tool:hover{border-color:var(--accent);color:var(--accent)}

/* YOUTUBE - embedded iframes (plays on site) */
.yt-section{background:#0a0a0a}
.yt-list{display:flex;flex-direction:column;gap:24px;max-width:880px;margin:0 auto}
.yt-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:all .3s}
.yt-card:hover{border-color:rgba(255,60,31,.35);box-shadow:0 8px 40px rgba(255,60,31,.12)}
.yt-frame-wrap{position:relative;width:100%;aspect-ratio:16/9;background:#000}
.yt-frame-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:0;display:block}
.yt-bar{padding:14px 18px;display:flex;align-items:center;gap:12px;border-top:1px solid var(--border)}
.yt-icon{width:32px;height:32px;background:#ff0000;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.yt-icon svg{width:16px;height:16px;fill:white}
.yt-info{flex:1}
.yt-vtitle{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--white);margin-bottom:2px}
.yt-vsub{font-size:11px;color:var(--gray)}
.yt-open{padding:7px 14px;border:1px solid var(--border);border-radius:4px;font-family:'Syne',sans-serif;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--gray);text-decoration:none;transition:all .3s;white-space:nowrap;flex-shrink:0}
.yt-open:hover{border-color:var(--accent);color:var(--accent)}

/* SHORT FORM - playable on site */
.short-section{background:var(--bg)}
.shorts-row{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;max-width:1240px;margin:0 auto}
.sv-card{border-radius:12px;overflow:hidden;border:1px solid var(--border);background:#111;position:relative;transition:all .4s}
.sv-card:hover{border-color:rgba(255,60,31,.5);transform:translateY(-5px);box-shadow:0 16px 40px rgba(255,60,31,.15)}
.sv-inner{position:relative;aspect-ratio:9/16;overflow:hidden;background:#000}
.sv-inner video{width:100%;height:100%;object-fit:cover;display:block;cursor:pointer}
.sv-foot{position:absolute;bottom:0;left:0;right:0;padding:36px 12px 12px;background:linear-gradient(transparent,rgba(0,0,0,0.85));pointer-events:none}
.sv-tag{font-family:'Syne',sans-serif;font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:3px}
.sv-lbl{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:white}
.drive-btn-wrap{display:flex;justify-content:center;margin-top:40px}
.drive-btn{display:inline-flex;align-items:center;gap:12px;background:var(--accent);color:var(--white);padding:16px 32px;border-radius:4px;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:all .3s;box-shadow:0 12px 40px rgba(255,60,31,.25)}
.drive-btn:hover{background:var(--accent2);transform:translateY(-2px)}

.clients-section{background:#0a0a0a}
.clients-cols{display:grid;grid-template-columns:1fr 1fr;gap:40px}
.col-head{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gray);margin-bottom:18px;padding-bottom:10px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.cr-link{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border:1px solid var(--border);border-radius:6px;background:var(--bg);margin-bottom:10px;text-decoration:none;transition:all .3s}
.cr-link:hover{border-color:rgba(255,60,31,.4);background:var(--bg2);transform:translateX(5px)}
.cr-name{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--white)}
.cr-arr{color:var(--gray);font-size:16px;transition:all .3s}
.cr-link:hover .cr-arr{color:var(--accent);transform:translateX(3px)}
.testi-section{background:var(--bg)}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.testi-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:28px 26px;transition:all .4s;position:relative;overflow:hidden}
.testi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--accent),var(--accent2));opacity:0;transition:opacity .4s}
.testi-card:hover::before{opacity:1}
.testi-card:hover{transform:translateY(-4px);border-color:rgba(255,60,31,.2);box-shadow:0 12px 40px rgba(255,60,31,.08)}
.testi-quote{font-size:36px;color:var(--accent);line-height:1;margin-bottom:14px;font-family:Georgia,serif}
.testi-stars{color:#ff6b00;font-size:13px;margin-bottom:14px;letter-spacing:2px}
.testi-text{font-size:14px;line-height:1.75;color:rgba(245,245,240,0.82);font-weight:300;margin-bottom:22px;font-style:italic}
.testi-author{display:flex;align-items:center;gap:12px;border-top:1px solid var(--border);padding-top:18px}
.testi-av{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:16px;color:white;flex-shrink:0}
.testi-name{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--white)}
.testi-role{font-size:11px;color:var(--gray);margin-top:2px}
.nevox-section{background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:80px 60px}
.nevox-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.nv-badge{display:inline-flex;align-items:center;gap:8px;padding:5px 12px;border:1px solid rgba(255,107,0,.25);border-radius:2px;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--accent2);font-weight:600;margin-bottom:18px}
.nv-title{font-family:'Bebas Neue',sans-serif;font-size:52px;line-height:.95;color:var(--white);margin-bottom:18px}
.nv-title span{color:var(--accent2)}
.nv-desc{font-size:14px;line-height:1.75;color:var(--gray);font-weight:300;margin-bottom:28px}
.nv-desc strong{color:var(--white);font-weight:500}
.nv-services{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.nv-svc{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--gray);font-weight:300}
.nv-svc::before{content:'';width:5px;height:5px;background:var(--accent2);border-radius:50%;flex-shrink:0}
.nv-visual{background:linear-gradient(135deg,rgba(255,107,0,.07),rgba(255,60,31,.03));border:1px solid rgba(255,107,0,.1);border-radius:10px;padding:50px 36px;text-align:center}
.nv-quote{font-family:'Bebas Neue',sans-serif;font-size:30px;color:rgba(255,107,0,.45);letter-spacing:2px;line-height:1.3;margin-bottom:14px}
.nv-sub{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,107,0,.3)}
.contact-section{background:var(--bg);text-align:center;padding:110px 60px}
.contact-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(55px,8vw,110px);line-height:.95;color:var(--white);margin-bottom:22px}
.contact-title .ol{color:transparent;-webkit-text-stroke:1px rgba(255,255,255,.13)}
.contact-desc{font-size:15px;color:var(--gray);max-width:460px;margin:0 auto 44px;font-weight:300;line-height:1.7}
.contact-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.cbtn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;border-radius:3px;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none;transition:all .3s}
.cbtn-email{background:var(--accent);color:var(--white)}
.cbtn-email:hover{background:var(--accent2);transform:translateY(-2px)}
.cbtn-ig{background:transparent;color:var(--white);border:1px solid rgba(255,255,255,.15)}
.cbtn-ig:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}
.cbtn svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}
footer{background:var(--bg2);border-top:1px solid var(--border);padding:28px 60px;display:flex;justify-content:space-between;align-items:center}
.ft-logo{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:3px;color:var(--gray)}
.ft-logo span{color:var(--accent)}
.ft-copy{font-size:11px;color:rgba(136,136,128,.45)}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.rv{opacity:0;transform:translateY(36px);transition:all .75s cubic-bezier(.16,1,.3,1)}
.rv.on{opacity:1;transform:translateY(0)}
@media(max-width:900px){
  nav{padding:16px 20px}.nav-links{display:none}
  .hero{grid-template-columns:1fr;padding:100px 20px 50px;text-align:center}
  .hero-right{justify-content:center;margin-top:36px}
  .photo-wrap{width:260px;height:325px}
  .badge1,.badge2{display:none}
  section,.nevox-section,.contact-section{padding:60px 20px}
  .skills-grid{grid-template-columns:1fr 1fr}
  .shorts-row{grid-template-columns:1fr 1fr}
  .clients-cols{grid-template-columns:1fr}
  .testi-grid{grid-template-columns:1fr}
  .nevox-inner{grid-template-columns:1fr;gap:36px}
  .stats-bar{grid-template-columns:repeat(2,1fr);padding:20px}
  footer{flex-direction:column;gap:8px;text-align:center;padding:20px}
  .yt-list{max-width:100%}
}
@media(max-width:480px){
  .skills-grid{grid-template-columns:1fr}
  .shorts-row{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>

<nav>
  <a href="#home" class="nav-logo">HARRY<span>.</span></a>
  <ul class="nav-links">
    <li><a href="#skills">Skills</a></li>
    <li><a href="#work">Work</a></li>
    <li><a href="#clients">Clients</a></li>
    <li><a href="#nevox">Agency</a></li>
    <li><a href="#contact" class="nav-hire">Hire Me</a></li>
  </ul>
</nav>

<section class="hero" id="home">
  <div class="hero-bg"></div><div class="hero-grid"></div>
  <div class="hero-left">
    <div class="hero-tag">Video Editor & Content Strategist</div>
    <h1 class="hero-name">HARRY<br><span class="acc">CHOUHAN</span></h1>
    <p class="hero-desc">I craft <strong>cinematic stories</strong> that stop the scroll. YouTube long-form, viral short-form, 3D edits & documentary — I do it all.</p>
    <div class="hero-btns">
      <a href="#work" class="btn-red">View Work <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      <a href="#contact" class="btn-ghost">Let's Talk <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
    </div>
  </div>
  <div class="hero-right">
    <div class="photo-wrap">
      <img src="data:image/webp;base64," alt="Harry Chouhan" class="hero-photo">
      <div class="badge1"><div class="badge1-num">5+</div><div class="badge1-txt">Major Creators</div></div>
      <div class="badge2">🔥 Available for Work</div>
    </div>
  </div>
</section>

<div class="marquee-wrap">
  <div class="marquee-track">
    <span class="m-item">YOUTUBE LONG FORM <span>✦</span></span><span class="m-item">SHORT FORM REELS <span>✦</span></span><span class="m-item">3D VIDEO EDITING <span>✦</span></span><span class="m-item">DOCUMENTARY STYLE <span>✦</span></span><span class="m-item">COLOR GRADING <span>✦</span></span><span class="m-item">MOTION GRAPHICS <span>✦</span></span><span class="m-item">KINETIC TYPOGRAPHY <span>✦</span></span><span class="m-item">YOUTUBE LONG FORM <span>✦</span></span><span class="m-item">SHORT FORM REELS <span>✦</span></span><span class="m-item">3D VIDEO EDITING <span>✦</span></span><span class="m-item">DOCUMENTARY STYLE <span>✦</span></span><span class="m-item">COLOR GRADING <span>✦</span></span><span class="m-item">MOTION GRAPHICS <span>✦</span></span><span class="m-item">KINETIC TYPOGRAPHY <span>✦</span></span>
  </div>
</div>

<div class="stats-bar rv">
  <div class="stat-item"><div class="stat-num">20<span>+</span></div><div class="stat-label">Creators Worked With</div></div>
  <div class="stat-item"><div class="stat-num">3<span>B+</span></div><div class="stat-label">Views Generated</div></div>
  <div class="stat-item"><div class="stat-num">6<span>+</span></div><div class="stat-label">Editing Styles</div></div>
  <div class="stat-item"><div class="stat-num">5</div><div class="stat-label">Pro Tools Mastered</div></div>
</div>

<section style="background:var(--bg)" id="skills">
  <div class="rv"><div class="sec-tag">What I Do</div><h2 class="sec-title">EDITING<br><span class="ol">STYLES</span></h2></div>
  <div class="skills-grid rv">
    <div class="sk-card"><span class="sk-icon">🎬</span><div class="sk-num">01</div><div class="sk-name">YouTube Long Form</div><div class="sk-desc">Cinematic cuts, b-roll, pacing & storytelling that keeps viewers hooked.</div></div>
    <div class="sk-card"><span class="sk-icon">📱</span><div class="sk-num">02</div><div class="sk-name">Short Form / Reels</div><div class="sk-desc">Scroll-stopping vertical videos with viral hooks for Shorts, Reels & TikTok.</div></div>
