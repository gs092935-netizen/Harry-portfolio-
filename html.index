<script>
// Suppress all console messages
window.onerror = function(){ return true; };
console.log = console.error = console.warn = console.info = function(){};

// Force external links to open even inside sandboxed preview iframes
document.addEventListener('click', function(e){
  var a = e.target.closest && e.target.closest('a[href]');
  if(!a) return;
  var href = a.getAttribute('href');
  if(!href) return;
  // In-page anchors: let browser handle smooth scroll
  if(href.charAt(0) === '#') return;
  // mailto/tel: try to open via top window
  if(/^(mailto:|tel:)/i.test(href)){
    e.preventDefault();
    try { (window.top || window).location.href = href; } catch(err) { window.location.href = href; }
    return;
  }
  // External http(s) links: force new tab via top window
  if(/^https?:\/\//i.test(href)){
    e.preventDefault();
    try { (window.top || window).open(href, '_blank', 'noopener,noreferrer'); }
    catch(err) { window.open(href, '_blank', 'noopener,noreferrer'); }
  }
});

// Scroll reveal - minimal
var ro = new IntersectionObserver(function(ens){
  ens.forEach(function(e,i){ if(e.isIntersecting) setTimeout(function(){e.target.classList.add('on');},i*80); });
},{threshold:0.07});
document.querySelectorAll('.rv').forEach(function(el){ro.observe(el);});

// Pause other shorts when one starts playing
var allShorts = document.querySelectorAll('.sv-inner video');
allShorts.forEach(function(v){
  v.addEventListener('play', function(){
    allShorts.forEach(function(o){ if(o!==v) o.pause(); });
  });
});
</script>
</body>
